{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["title", "summary", "topics", "key_events", "evidence_msg_ids", "confidence", "uncertainty"],
  "properties": {
    "title": { "type": "string" },
    "summary": { "type": "string" },
    "topics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "key_events": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_msg_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "uncertainty": { "type": "string" }
  },
  "additionalProperties": false
}

FROM golang:1.25 AS build

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/rel-analyzer ./cmd/rel-analyzer

FROM gcr.io/distroless/static-debian12:nonroot

WORKDIR /app

COPY --from=build /out/rel-analyzer /usr/local/bin/rel-analyzer
COPY llm /app/llm

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/rel-analyzer"]
